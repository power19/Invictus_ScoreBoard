{
  "name": "invictus-scoreboard",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "install:all": "npm install && npm --prefix server install && npm --prefix client install",
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "start": "concurrently \"cd server && npm start\" \"cd client && npm run preview\"",
    "build": "npm --prefix client run build",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win",
    "electron:publish": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.invictus.scoreboard",
    "productName": "Invictus Scoreboard",
    "files": [
      "electron/**/*",
      "server/index.js",
      "client/dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "power19",
      "repo": "Invictus_ScoreBoard"
    }
  }
}
